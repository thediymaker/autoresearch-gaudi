# ---------------------------------------------------------------------------
# autoresearch-gaudi configuration
#
# Copy this file to ".env" and fill in the values for your setup:
#
#     cp .env.example .env
#
# The .env file is read by analysis.ipynb (and can be sourced for the CLI
# harness). It is gitignored so your API key is never committed.
# ---------------------------------------------------------------------------

# --- Local OpenAI-compatible "brain" (the agent that proposes edits) --------
# Base URL of your OpenAI-compatible endpoint. MUST end in /v1.
# Examples:
#   - local vLLM on Gaudi:  http://localhost:8000/v1
#   - in-cluster service:   http://my-vllm.my-namespace.svc.cluster.local:8000/v1
#   - OpenAI itself:        https://api.openai.com/v1
OPENAI_BASE_URL=http://localhost:8000/v1

# Bearer key sent as "Authorization: Bearer <key>".
# For a local vLLM server any non-empty placeholder works (e.g. "sk-local").
OPENAI_API_KEY=sk-local

# Model name to request from the endpoint above (must match what the server serves).
OPENAI_MODEL=my-model

# --- Where train.py actually runs -------------------------------------------
# AUTORESEARCH_RUNNER selects how the scorer executes each training experiment:
#   local  - run train.py directly on THIS machine. Use this when the notebook /
#            harness runs ON the Gaudi node or inside the Gaudi pod (e.g. the
#            JupyterLab template, where repo + HPU are co-located). No kubectl.
#   k8s    - kubectl cp + exec into a separate debug pod (cross-cluster driving).
#   (unset)- auto-detect: k8s if kubectl + a Running pod are found, else local.
AUTORESEARCH_RUNNER=local

# Only used when AUTORESEARCH_RUNNER=k8s. Match your debug pod's name/namespace.
AUTORESEARCH_NAMESPACE=autoresearch
AUTORESEARCH_POD=autoresearch-debug

# --- Experiment loop defaults -----------------------------------------------
# Which experiment directory the harness drives, and how many iterations to run.
AUTORESEARCH_EXPERIMENT=experiments/gpt_train
AUTORESEARCH_ITERATIONS=5
